# ============================================================
# Chinai Gateway — Environment Variables
# Copy this to .env and fill in your API keys
# ============================================================

# Gateway master key — used for admin UI login and API auth
LITELLM_MASTER_KEY=sk-change-me-to-a-random-string
LITELLM_SALT_KEY=salt-change-me-to-another-random-string

# Port to expose the gateway on
LITELLM_PORT=4000

# Admin UI credentials
UI_USERNAME=admin
UI_PASSWORD=change-me

# ============================================================
# Model Provider API Keys
# Only fill in the ones you need. Leave blank to disable.
# ============================================================

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Alibaba Qwen (DashScope) — https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-your-qwen-key

# Zhipu GLM — https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=your-zhipu-key

# Moonshot Kimi — https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=sk-your-kimi-key

# Baidu ERNIE (Qianfan) — https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
BAIDU_API_KEY=sk-your-baidu-key
