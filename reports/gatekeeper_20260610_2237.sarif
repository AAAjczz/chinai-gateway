{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.6.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Gatekeeper",
          "version": "1.0.0",
          "informationUri": "https://github.com/AAAjczz/gatekeeper",
          "rules": [
            {
              "id": "SEC-001",
              "name": "Hardcoded Secrets in Managed Config Files",
              "shortDescription": {
                "text": "2 real API keys found in config files (should use env vars)"
              },
              "help": {
                "text": "Category: secrets\n\nFix:\nReplace hardcoded keys with env var references:\n  api_key: ${DEEPSEEK_API_KEY}\nUse .env for local values, but NEVER commit .env to git."
              },
              "properties": {
                "category": "secrets"
              }
            },
            {
              "id": "SEC-002",
              "name": ".gitignore Protects Secrets",
              "shortDescription": {
                "text": "All .env patterns properly excluded from git"
              },
              "help": {
                "text": "Category: secrets"
              },
              "properties": {
                "category": "secrets"
              }
            },
            {
              "id": "SEC-003",
              "name": "No Default Keys in Active Config",
              "shortDescription": {
                "text": "No placeholder or default API keys in active config files"
              },
              "help": {
                "text": "Category: secrets"
              },
              "properties": {
                "category": "secrets"
              }
            },
            {
              "id": "SEC-004",
              "name": "Weak API Master Key",
              "shortDescription": {
                "text": "Master key in .env is only 24 chars — brute-forceable"
              },
              "help": {
                "text": "Category: secrets\n\nFix:\nGenerate a strong key:\n  openssl rand -hex 32\nOr use a password manager to generate a 64-char random string."
              },
              "properties": {
                "category": "secrets"
              }
            },
            {
              "id": "SEC-005",
              "name": "Key Rotation Policy Found",
              "shortDescription": {
                "text": "Key rotation documentation detected"
              },
              "help": {
                "text": "Category: secrets"
              },
              "properties": {
                "category": "secrets"
              }
            },
            {
              "id": "NET-003",
              "name": "Port Exposure",
              "shortDescription": {
                "text": "All 1 port(s) bound to localhost — safe"
              },
              "help": {
                "text": "Category: network"
              },
              "properties": {
                "category": "network"
              }
            },
            {
              "id": "CFG-001",
              "name": "Rate Limiting Configured",
              "shortDescription": {
                "text": "Rate limiting found in config.yaml"
              },
              "help": {
                "text": "Category: config"
              },
              "properties": {
                "category": "config"
              }
            },
            {
              "id": "CFG-002",
              "name": "Resource Limits Configured",
              "shortDescription": {
                "text": "Container resource limits found"
              },
              "help": {
                "text": "Category: config"
              },
              "properties": {
                "category": "config"
              }
            },
            {
              "id": "CFG-003",
              "name": "Debug Mode Disabled",
              "shortDescription": {
                "text": "No debug/verbose settings detected in production config"
              },
              "help": {
                "text": "Category: config"
              },
              "properties": {
                "category": "config"
              }
            },
            {
              "id": "DEP-001",
              "name": "Running as Root — Partial Mitigations Present",
              "shortDescription": {
                "text": "Containers run as root but have partial hardening"
              },
              "help": {
                "text": "Category: deployment\n\nFix:\nFor stronger defense, add:\n  user: \"1000:1000\""
              },
              "properties": {
                "category": "deployment"
              }
            },
            {
              "id": "DEP-002",
              "name": "No Privileged Mode",
              "shortDescription": {
                "text": "No containers in privileged mode"
              },
              "help": {
                "text": "Category: deployment"
              },
              "properties": {
                "category": "deployment"
              }
            },
            {
              "id": "DEP-003",
              "name": "Writable Root Filesystem",
              "shortDescription": {
                "text": "Containers have writable root filesystem"
              },
              "help": {
                "text": "Category: deployment\n\nFix:\nAdd: read_only: true (with tmpfs for /tmp if needed)"
              },
              "properties": {
                "category": "deployment"
              }
            },
            {
              "id": "DEP-004",
              "name": "Unpinned Docker Images (:latest)",
              "shortDescription": {
                "text": "1 image(s) use floating tags — can break silently"
              },
              "help": {
                "text": "Category: deployment\n\nFix:\nPin images to specific SHA or version tags:\n  image: litellm:1.75.0  # not :latest\nConsider using Dependabot or Renovate for automated updates."
              },
              "properties": {
                "category": "deployment"
              }
            },
            {
              "id": "DEP-005",
              "name": "Health Checks Configured",
              "shortDescription": {
                "text": "2 healthcheck(s) found"
              },
              "help": {
                "text": "Category: deployment"
              },
              "properties": {
                "category": "deployment"
              }
            },
            {
              "id": "DEP-006",
              "name": "Restart Policy Set",
              "shortDescription": {
                "text": "All 2 services have restart policies"
              },
              "help": {
                "text": "Category: deployment"
              },
              "properties": {
                "category": "deployment"
              }
            },
            {
              "id": "DEP-007",
              "name": "Docker Socket Not Exposed",
              "shortDescription": {
                "text": "Docker socket not mounted in containers"
              },
              "help": {
                "text": "Category: deployment"
              },
              "properties": {
                "category": "deployment"
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "SEC-001",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "text": "  .env.example: sk-***ere\n  .env.example: sk-***key"
          },
          "kind": "fail"
        },
        {
          "ruleId": "SEC-002",
          "ruleIndex": 1,
          "level": "error",
          "message": {
            "text": "All .env patterns properly excluded from git"
          },
          "kind": "pass"
        },
        {
          "ruleId": "SEC-003",
          "ruleIndex": 2,
          "level": "error",
          "message": {
            "text": "No placeholder or default API keys in active config files"
          },
          "kind": "pass"
        },
        {
          "ruleId": "SEC-004",
          "ruleIndex": 3,
          "level": "error",
          "message": {
            "text": "File: .env, key length: 24 (minimum recommended: 32)"
          },
          "kind": "fail"
        },
        {
          "ruleId": "SEC-005",
          "ruleIndex": 4,
          "level": "warning",
          "message": {
            "text": "Key rotation documentation detected"
          },
          "kind": "pass"
        },
        {
          "ruleId": "NET-003",
          "ruleIndex": 5,
          "level": "error",
          "message": {
            "text": "All 1 port(s) bound to localhost — safe"
          },
          "kind": "pass"
        },
        {
          "ruleId": "CFG-001",
          "ruleIndex": 6,
          "level": "error",
          "message": {
            "text": "Rate limiting found in config.yaml"
          },
          "kind": "pass"
        },
        {
          "ruleId": "CFG-002",
          "ruleIndex": 7,
          "level": "warning",
          "message": {
            "text": "Container resource limits found"
          },
          "kind": "pass"
        },
        {
          "ruleId": "CFG-003",
          "ruleIndex": 8,
          "level": "error",
          "message": {
            "text": "No debug/verbose settings detected in production config"
          },
          "kind": "pass"
        },
        {
          "ruleId": "DEP-001",
          "ruleIndex": 9,
          "level": "warning",
          "message": {
            "text": "Mitigations: security_opt: no-new-privileges (blocks privilege escalation)"
          },
          "kind": "fail"
        },
        {
          "ruleId": "DEP-002",
          "ruleIndex": 10,
          "level": "error",
          "message": {
            "text": "No containers in privileged mode"
          },
          "kind": "pass"
        },
        {
          "ruleId": "DEP-003",
          "ruleIndex": 11,
          "level": "warning",
          "message": {
            "text": "Increases attack surface if container is compromised"
          },
          "kind": "fail"
        },
        {
          "ruleId": "DEP-004",
          "ruleIndex": 12,
          "level": "warning",
          "message": {
            "text": "Images: ghcr.io/aaajczz/chinai-gateway:latest"
          },
          "kind": "fail"
        },
        {
          "ruleId": "DEP-005",
          "ruleIndex": 13,
          "level": "warning",
          "message": {
            "text": "2 healthcheck(s) found"
          },
          "kind": "pass"
        },
        {
          "ruleId": "DEP-006",
          "ruleIndex": 14,
          "level": "warning",
          "message": {
            "text": "All 2 services have restart policies"
          },
          "kind": "pass"
        },
        {
          "ruleId": "DEP-007",
          "ruleIndex": 15,
          "level": "error",
          "message": {
            "text": "Docker socket not mounted in containers"
          },
          "kind": "pass"
        }
      ]
    }
  ]
}